<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_night">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:background="@color/bg_night">
        <Button
            android:id="@+id/btn_master"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="👑 Master"
            android:textSize="12sp"
            android:background="@drawable/bg_card_dark"
            android:paddingHorizontal="14dp"
            android:textColor="@color/text_secondary"/>
    </LinearLayout>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:background="@color/header_night">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌑"
            android:textSize="40sp"/>

        <TextView
            android:id="@+id/tv_wendigo_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="#5D11B1"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:padding="12dp"
            android:background="@drawable/bg_card_dark"/>
    </LinearLayout>

    <!-- Target selection (hidden when dead) -->
    <LinearLayout
        android:id="@+id/layout_action"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Il wendigo sceglie un bersaglio:"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:padding="20dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_targets"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="16dp"
            android:clipToPadding="false"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Il wendigo indovina il ruolo:"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:paddingHorizontal="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp">

            <RadioGroup
                android:id="@+id/rg_roles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp"/>
        </ScrollView>

        <Button
            android:id="@+id/btn_wendigo_act"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🌑 Usa potere"
            android:textSize="16sp"
            android:background="@drawable/bg_button_primary"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"/>

        <Button
            android:id="@+id/btn_wendigo_skip"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Salta turno"
            android:textSize="14sp"
            android:background="@drawable/bg_card_dark"
            android:textColor="@color/text_secondary"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"/>

    </LinearLayout>

    <!-- Shown when dead (instead of action layout) -->
    <Button
        android:id="@+id/btn_continue_dead"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Continua"
        android:textSize="18sp"
        android:background="@drawable/bg_button_primary"
        android:layout_margin="16dp"
        android:visibility="gone"/>

</LinearLayout>
