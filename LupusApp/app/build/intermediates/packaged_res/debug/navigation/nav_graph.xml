<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/setupFragment">

    <fragment
        android:id="@+id/setupFragment"
        android:name="com.lupus.game.ui.setup.SetupFragment"
        android:label="Setup"
        tools:layout="@layout/fragment_setup">
        <action
            android:id="@+id/action_setup_to_names"
            app:destination="@id/playerNamesFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"/>
    </fragment>

    <fragment
        android:id="@+id/playerNamesFragment"
        android:name="com.lupus.game.ui.setup.PlayerNamesFragment"
        android:label="Nomi"
        tools:layout="@layout/fragment_player_names">
        <argument
            android:name="playerCount"
            app:argType="integer"
            android:defaultValue="4"/>
        <action
            android:id="@+id/action_names_to_roles"
            app:destination="@id/rolesSetupFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"/>
    </fragment>

    <fragment
        android:id="@+id/rolesSetupFragment"
        android:name="com.lupus.game.ui.setup.RolesSetupFragment"
        android:label="Ruoli"
        tools:layout="@layout/fragment_roles_setup">
        <action
            android:id="@+id/action_roles_to_reveal"
            app:destination="@id/roleRevealFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popUpTo="@id/setupFragment"
            app:popUpToInclusive="false"/>
    </fragment>

    <fragment
        android:id="@+id/roleRevealFragment"
        android:name="com.lupus.game.ui.setup.RoleRevealFragment"
        android:label="Ruoli Segreti"
        tools:layout="@layout/fragment_role_reveal">
        <action
            android:id="@+id/action_reveal_to_seer"
            app:destination="@id/nightSeerFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popUpTo="@id/setupFragment"
            app:popUpToInclusive="false"/>
        <action
            android:id="@+id/action_reveal_to_wolves"
            app:destination="@id/nightWolvesFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popUpTo="@id/setupFragment"
            app:popUpToInclusive="false"/>
    </fragment>

    <fragment
        android:id="@+id/nightSeerFragment"
        android:name="com.lupus.game.ui.night.NightSeerFragment"
        android:label="Notte - Veggente"
        tools:layout="@layout/fragment_night_seer">
        <action
            android:id="@+id/action_night_seer_to_wolves"
            app:destination="@id/nightWolvesFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"/>
        <action
            android:id="@+id/action_night_seer_to_vigilante"
            app:destination="@id/vigilanteFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"/>
        <action
            android:id="@+id/action_night_seer_to_day"
            app:destination="@id/dayVoteFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"/>
        <action
            android:id="@+id/action_night_seer_to_result"
            app:destination="@id/gameResultFragment"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out"/>
    </fragment>

    <fragment
        android:id="@+id/vigilanteFragment"
        android:name="com.lupus.game.ui.night.VigilanteFragment"
        android:label="Notte - Giustiziere"
        tools:layout="@layout/fragment_vigilante">
        <action
            android:id="@+id/action_vigilante_to_wolves"
            app:destination="@id/nightWolvesFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"/>
        <action
            android:id="@+id/action_vigilante_to_day"
            app:destination="@id/dayVoteFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"/>
        <action
            android:id="@+id/action_vigilante_to_result"
            app:destination="@id/gameResultFragment"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out"/>
    </fragment>

    <fragment
        android:id="@+id/nightWolvesFragment"
        android:name="com.lupus.game.ui.night.NightWolvesFragment"
        android:label="Notte - Lupi"
        tools:layout="@layout/fragment_night_wolves">
        <action
            android:id="@+id/action_night_wolves_to_day"
            app:destination="@id/dayVoteFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"/>
        <action
            android:id="@+id/action_night_wolves_to_result"
            app:destination="@id/gameResultFragment"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out"/>
        <action
            android:id="@+id/action_night_wolves_to_vigilante"
            app:destination="@id/vigilanteFragment"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out"/>
    </fragment>

    <fragment
        android:id="@+id/dayVoteFragment"
        android:name="com.lupus.game.ui.day.DayVoteFragment"
        android:label="Giorno - Voto"
        tools:layout="@layout/fragment_day_vote">
        <action
            android:id="@+id/action_day_to_vote_result"
            app:destination="@id/voteResultFragment"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out"/>
        <action
            android:id="@+id/action_day_to_result"
            app:destination="@id/gameResultFragment"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out"/>
    </fragment>

    <fragment
        android:id="@+id/voteResultFragment"
        android:name="com.lupus.game.ui.day.VoteResultFragment"
        android:label="Risultato Voto"
        tools:layout="@layout/fragment_vote_result">
        <action
            android:id="@+id/action_vote_result_to_seer"
            app:destination="@id/nightSeerFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popUpTo="@id/nightSeerFragment"
            app:popUpToInclusive="true"/>
        <action
            android:id="@+id/action_vote_result_to_wolves"
            app:destination="@id/nightWolvesFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popUpTo="@id/nightWolvesFragment"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/gameResultFragment"
        android:name="com.lupus.game.ui.result.GameResultFragment"
        android:label="Fine Partita"
        tools:layout="@layout/fragment_result">
        <action
            android:id="@+id/action_result_to_setup"
            app:destination="@id/setupFragment"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out"
            app:popUpTo="@id/setupFragment"
            app:popUpToInclusive="true"/>
    </fragment>

</navigation>