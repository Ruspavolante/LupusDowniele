<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_day">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:background="@color/header_day">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☀️"
            android:textSize="40sp"/>

        <TextView
            android:id="@+id/tv_day_round"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"/>

        <TextView
            android:id="@+id/tv_alive_players"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="@color/text_dark_secondary"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Il villaggio vota chi eliminare:"
            android:textSize="18sp"
            android:textColor="@color/text_primary"/>

        <Button
            android:id="@+id/btn_death_log"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="📜 Cronologia"
            android:textSize="13sp"
            android:background="@drawable/bg_button_primary"
            android:paddingHorizontal="12dp"/>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_vote_players"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"/>

    <Button
        android:id="@+id/btn_eliminate"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="🗳️ Elimina giocatore"
        android:textSize="18sp"
        android:background="@drawable/bg_button_danger"
        android:layout_margin="16dp"/>

</LinearLayout>
